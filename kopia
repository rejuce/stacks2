version: '3.7'
services:
    kopia:
        image: kopia/kopia:latest
        hostname: Hostname
        container_name: Kopia
        restart: unless-stopped
        ports:
            - 51515:51515
        # Setup the server that provides the web gui
        command:
            - server
            - start
            - --disable-csrf-token-checks
            - --insecure
            - --address=0.0.0.0:51515
            - --server-username=jk
            - --server-password=a
        environment:
            # Set repository password
            KOPIA_PASSWORD: "a"
            USER: "jk"
        volumes:
            # Mount local folders needed by kopia
            - /home/jk/_dockervolumes/kopia/config:/app/config
            - /home/jk/_dockervolumes/kopia/cache:/app/cache
            - /home/jk/_dockervolumes/kopia/logs:/app/logs
            # Mount local folders to snapshot
            - /mnt/dm5:/data:ro
            # Mount repository location
            - /mnt/backup/kopiaRepo:/repository
            # Mount path for browsing mounted snaphots
            - /home/jk/_dockervolumes/kopia/sharedmount:/tmp
