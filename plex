version: "3.8"
services:
  plex:
    image: lscr.io/linuxserver/plex:1.41.3
    container_name: plex
    network_mode: host
    environment:
      - PUID=1000          # your user id
      - PGID=1000          # your group id
      - TZ=Europe/London   # <-- set your timezone here
      - VERSION=docker
      - UMASK_SET=022
    devices:
      - /dev/dri:/dev/dri
    volumes:
      - /home/jk/_dockervolumes/plex/config:/config
      - /home/jk/_dockervolumes/plex/transcode:/transcode
      - /mnt/dm5:/data/
    shm_size: "1g"
    restart: unless-stopped
